<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InkscapeTileMaker.Views.LandingPage"
             xmlns:vms="clr-namespace:InkscapeTileMaker.ViewModels"
             x:DataType="vms:LandingViewModel">
    <Grid RowDefinitions="50, Auto, *"
          ColumnDefinitions="0.3*, 0.7*"
          Padding="50,0,50,0"
          ColumnSpacing="5">

        <Grid Grid.Row="0"
              Grid.ColumnSpan="2">
            <ImageButton Grid.Column="1"
                         Source="settings.png"
                         Command="{Binding OpenSettingsCommand}"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         WidthRequest="16"
                         HeightRequest="16"
                         Padding="0"
                         BackgroundColor="Transparent"
                         BorderWidth="0"
                         SemanticProperties.Description="Settings" />
        </Grid>

        <Grid Grid.Row="1"
              Grid.ColumnSpan="2"
              ColumnDefinitions="*, Auto">
            <Label 
                Text="Welcome to Inkscape Tile Maker!"
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Grid.ColumnSpan="2"
                FontSize="Title"/>
        </Grid>

        <VerticalStackLayout
            Grid.Row="2"
            Grid.Column="0"
            Spacing="5"
            VerticalOptions="Start"
            Padding="0, 15">
            <Button 
                Text="Create New"
                Command="{Binding CreateNewDesignCommand}"/>
            <Button 
                Text="Open Existing"
                Command="{Binding OpenExistingDesignCommand}"/>
        </VerticalStackLayout>

        <StackLayout
            Grid.Row="2"
            Grid.Column="1"
            Padding="10">
            <Label 
                Text="Create SVG-based tilesets for use in games, using Inkscape. Get started by creating a new design or opening an existing one."
                FontSize="Body"
                VerticalOptions="Center"
                HorizontalOptions="Center"/>
        </StackLayout>

    </Grid>
</ContentPage>