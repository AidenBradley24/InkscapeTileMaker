<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="InkscapeTileMaker.Views.IndividualTileView"
             xmlns:vms="clr-namespace:InkscapeTileMaker.ViewModels"
             xmlns:models="clr-namespace:InkscapeTileMaker.Models;assembly=InkscapeTileMaker.Models"
             x:DataType="vms:DesignerViewModel"
             xmlns:ctrls="clr-namespace:InkscapeTileMaker.Controls"
             xmlns:conv="clr-namespace:InkscapeTileMaker.Converters"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:behaviors="clr-namespace:InkscapeTileMaker.Behaviors"
             x:Name="IndividualTile">

    <ContentView.Resources>
        <conv:EnumToItemsSourceConverter x:Key="EnumToItemsSourceConverter" />
        <toolkit:IsListNotNullOrEmptyConverter x:Key="IsListNotNullOrEmptyConverter" />
    </ContentView.Resources>

    <!-- Use Grid so the ScrollView row gets a bounded height and can scroll -->
    <Grid Padding="12" RowSpacing="12"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- Row 0: toolbar -->
        <HorizontalStackLayout Grid.Row="0"
                               Spacing="5"
                               HeightRequest="40">
            <ctrls:ToolIcon ToolName="Return to Tileset"
                            Command="{Binding ReturnToTileSetCommand}"
                            Source="arrow_left.png"
                            UnselectedOutlineStroke="WhiteSmoke"
                            BackgroundColor="White"
                            WidthRequest="40" />
            <ctrls:ToolIcon ToolName="Delete"
                            Command="{Binding DeleteSelectedTileCommand}"
                            Source="trash.png"
                            UnselectedOutlineStroke="WhiteSmoke"
                            BackgroundColor="White"
                            WidthRequest="40" />
        </HorizontalStackLayout>

        <!-- Row 1: error bar -->
        <Grid Grid.Row="1"
              IsVisible="{Binding SelectedTile.HasErrors}"
              BackgroundColor="Orange">
            <Label Text="{Binding SelectedTile.CurrentErrorMessage}"
                   TextColor="White"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Margin="4" />
        </Grid>

        <!-- Row 2: preview -->
        <Grid Grid.Row="2"
              HeightRequest="128">
            <Border Stroke="LightGray"
                    StrokeThickness="1"
                    Padding="4"
                    HorizontalOptions="Center"
                    VerticalOptions="Center">
                <Image Source="{Binding SelectedTile.PreviewImage}"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>
        </Grid>

        <!-- Row 3: tile set position -->
        <Grid Grid.Row="3"
              ColumnDefinitions="100, *">
            <Label Grid.Column="0"
                   Text="Tile Set Position"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center"
                   Margin="0,4,8,0" />
            <Label Grid.Column="1"
                   Text="{Binding SelectedTile.Position, StringFormat='{}{0.col}, {0.row}'}"
                   VerticalTextAlignment="Center"
                   Margin="0,4,0,0" />
        </Grid>

        <!-- Row 4: name -->
        <Grid Grid.Row="4"
              ColumnDefinitions="100, *">
            <Label Grid.Column="0"
                   Text="Name"
                   FontAttributes="Bold"
                   VerticalTextAlignment="Center"
                   Margin="0,0,8,0" />
            <Entry Grid.Column="1"
                   Text="{Binding SelectedTile.Name, Mode=TwoWay}"
                   VerticalTextAlignment="Center"
                   Margin="0,0,0,0" />
        </Grid>

        <!-- Row 5: scrollable content -->
        <ScrollView Grid.Row="5"
                    Orientation="Vertical">
            <VerticalStackLayout Padding="12" Spacing="12">

                <Picker Title="Tile Type"
                        ItemsSource="{Binding SelectedTile.Type, Converter={StaticResource EnumToItemsSourceConverter}}"
                        SelectedItem="{Binding SelectedTile.Type, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Converter={StaticResource EnumToStringConverter}}"
                        Margin="0,12,0,0" />

                <Grid ColumnDefinitions="100, *"
                      IsVisible="{Binding SelectedTile.IsMaterial}">
                    <Label Grid.Column="0"
                           Text="Material Name"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           Margin="0,0,8,0" />
                    <Entry Grid.Column="1"
                           Text="{Binding SelectedTile.MaterialName, Mode=TwoWay}"
                           VerticalTextAlignment="Center"
                           Margin="0,0,0,0" />
                </Grid>

                <Picker Title="Variant"
                        ItemsSource="{Binding SelectedTile.VariantOptions}"
                        SelectedItem="{Binding SelectedTile.Variant, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Converter={StaticResource EnumToStringConverter}}"
                        Margin="0,12,0,0"
                        IsVisible="{Binding SelectedTile.IsMaterial}" />

                <Picker Title="Alignment"
                        ItemsSource="{Binding SelectedTile.AlignmentOptions}"
                        SelectedItem="{Binding SelectedTile.Alignment, Mode=TwoWay}"
                        ItemDisplayBinding="{Binding Converter={StaticResource EnumToStringConverter}}"
                        Margin="0,12,0,0"
                        IsVisible="{Binding SelectedTile.IsMaterial}" />

                <Grid ColumnDefinitions="100, *"
                      IsVisible="{Binding SelectedTile.IsMaterial}">
                    <Label Grid.Column="0"
                           Text="Priority"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           Margin="0,0,8,0" />
                    <Entry Text="{Binding SelectedTile.PriorityString, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Grid.Column="1" />
                </Grid>

                <Grid RowDefinitions="100, *"
                      ColumnDefinitions="*"
                      IsVisible="{Binding SelectedTile.SecondaryAlignmentOptions, Converter={StaticResource IsListNotNullOrEmptyConverter}}">
                    <Label Grid.Row="0"
                           Grid.Column="0"
                           Text="Secondary Alignments"
                           FontAttributes="Bold"
                           VerticalTextAlignment="Center"
                           Margin="0,0,8,0" />
                    <ctrls:MultiPicker Grid.Row="1"
                                       Items="{Binding SelectedTile.SecondaryAlignmentOptions}"
                                       SelectedItems="{Binding SelectedTile.SecondaryAlignments, Mode=TwoWay}"
                                       ItemDisplayBinding="{Binding Converter={StaticResource EnumToStringConverter}}">
                    </ctrls:MultiPicker>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentView>
